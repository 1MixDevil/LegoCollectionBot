# Telegram
TG_TOKEN=your_telegram_bot_token

# Ports (host mapping)
AUTHORIZATION_PORT=8000
COLLECTION_PORT=8001

# Internal Docker hostnames
AUTHORIZATION_IP=auth-service
COLLECTION_IP=collection-service

# Database
DATABASE_URL=postgresql+psycopg2://aml1:aml1@db:5432/lego_db
POSTGRES_HOST=db
POSTGRES_USER=aml1
POSTGRES_PASSWORD=aml1
POSTGRES_DB=lego_db

# Bot limits
MAX_SERIALS_PER_REQUEST=50

# === Каталог минифигурок (артикулы BrickLink: sw0001a, hp0023, …) ===
# /update — список catalogList BrickLink (cookies не нужны)
# rebrickable | bricklink — bricklink = поштучный перебор sw0001… (нужны cookies/API)
CATALOG_DATA_SOURCE=rebrickable
# Ключ Rebrickable (опционально, для будущих фич; /update его не использует)
REBRICKABLE_API_KEY=
REBRICKABLE_REQUEST_INTERVAL=1.05

# Пауза между запросами catalogList (сек), при 429 увеличьте до 3–5
BRICKLINK_CATALOG_DELAY=2.0

# Запасной вариант: BrickLink HTML (cookies, протухают) или Store API (нужен продавец)
# BRICKLINK_COOKIES=
# BRICKLINK_CONSUMER_KEY=
# BRICKLINK_CONSUMER_SECRET=
# BRICKLINK_TOKEN=
# BRICKLINK_TOKEN_SECRET=
# BRICKLINK_DATA_SOURCE=auto
# BRICKLINK_REQUEST_DELAY=0.7
