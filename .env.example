# Telegram
TG_TOKEN=your_telegram_bot_token
# Доп. администраторы (через запятую). 539686459 — владелец, admin всегда (код + миграция)
ADMIN_TELEGRAM_IDS=539686459

# Ports (host mapping)
AUTHORIZATION_PORT=8000
COLLECTION_PORT=8001

# Internal Docker hostnames
AUTHORIZATION_IP=auth-service
COLLECTION_IP=collection-service

# Database
DATABASE_URL=postgresql+psycopg2://aml1:aml1@db:5432/lego_db
POSTGRES_HOST=db
POSTGRES_USER=aml1
POSTGRES_PASSWORD=aml1
POSTGRES_DB=lego_db

# Bot limits (массовое добавление в коллекцию — без лимита)
MAX_SERIALS_PER_REQUEST=50

# === Celery + Redis (коллажи в фоне, VPS 4 GB) ===
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=1

# Коллаж / tier-list
COLLAGE_FORCE_BATCH_ABOVE=40
COLLAGE_BATCH_SIZE=50
CONCURRENT_BATCHES=4
COLLAGE_IMAGE_FORMAT=jpeg
COLLAGE_JPEG_QUALITY=85
COLL_MIN_HEIGHT=800
COLLAGE_CELL_PAD=80
COLLAGE_MAX_DIMENSION=10000
TIERLIST_MAX_FIGURES_MEMBER=100
TIERLIST_MAX_FIGURES_PREMIUM=200
TIERLIST_MAX_FIGURES_ADMIN=500

# Лимиты RAM Docker (сумма ~3.0–3.2 GB + запас под VPN/ОС на хосте 4 GB)
BOT_MEM_LIMIT=384m
CELERY_MEM_LIMIT=1536m
POSTGRES_MEM_LIMIT=512m
AUTH_MEM_LIMIT=256m
COLLECTION_MEM_LIMIT=256m
REDIS_MEM_LIMIT=192m
# Повторы при обрыве связи с api.telegram.org
TELEGRAM_RETRY_ATTEMPTS=3
TELEGRAM_RETRY_DELAY=2.0
TELEGRAM_DOCUMENT_TIMEOUT=600
# ↑ только карточка фигурки и tier-list по артикулам
TIERLIST_KEYWORD_MAX=500

# Поиск по фото (Brickognize, без API-ключа)
# BRICKOGNIZE_API_URL=https://api.brickognize.com/internal/search/
# BRICKOGNIZE_TIMEOUT=120

# === Каталог минифигурок (артикулы BrickLink: sw0001a, hp0023, …) ===
# /update — список catalogList BrickLink (cookies не нужны)
# rebrickable | bricklink — bricklink = поштучный перебор sw0001… (нужны cookies/API)
CATALOG_DATA_SOURCE=rebrickable
# Ключ Rebrickable (опционально, для будущих фич; /update его не использует)
REBRICKABLE_API_KEY=
REBRICKABLE_REQUEST_INTERVAL=1.05

# Пауза между запросами catalogList (сек), при 429 увеличьте до 3–5
BRICKLINK_CATALOG_DELAY=2.0
# Пауза между запросами Price Guide (карточка фигурки), при 429 — 2–3
BRICKLINK_PRICE_DELAY=1.0

# Цены на карточке: RUB (курс ЦБ РФ) | NATIVE — как на BrickLink (EUR/USD)
DISPLAY_CURRENCY=RUB
# CBR_RATES_URL=https://www.cbr-xml-daily.ru/daily_json.js

# Запасной вариант: BrickLink HTML (cookies, протухают) или Store API (нужен продавец)
# BRICKLINK_COOKIES=
# BRICKLINK_CONSUMER_KEY=
# BRICKLINK_CONSUMER_SECRET=
# BRICKLINK_TOKEN=
# BRICKLINK_TOKEN_SECRET=
# BRICKLINK_DATA_SOURCE=auto
# BRICKLINK_REQUEST_DELAY=0.7
